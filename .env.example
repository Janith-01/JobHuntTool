# MongoDB Connection
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=jobhunttool

# Google Gemini API Key (for AI Logic Layer)
GEMINI_API_KEY=your_gemini_api_key_here

# Email Configuration (Zoho / VertexStack)
EMAIL_HOST=smtp.zoho.com
EMAIL_PORT=465
EMAIL_USER=your_email@vertexstack.com
EMAIL_PASSWORD=your_email_password_here

# Scraping Configuration
SCRAPE_INTERVAL_MINUTES=60
MAX_CONCURRENT_SCRAPERS=3
REQUEST_DELAY_SECONDS=2

# LinkedIn Credentials (Optional - for authenticated scraping)
LINKEDIN_EMAIL=your_linkedin_email
LINKEDIN_PASSWORD=your_linkedin_password

# Application Settings
APP_ENV=development
API_PORT=8000
FRONTEND_PORT=3000

# PDF Generation
PDF_OUTPUT_DIR=./output/pdfs
CV_TEMPLATE_DIR=./templates

# Master CV Path
MASTER_CV_PATH=./data/master_cv.json
